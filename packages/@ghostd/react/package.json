{
  "name": "@ghostd/react",
  "version": "0.1.0",
  "description": "React components for ghostd terminals",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./css": {
      "style": "./src/styles.css",
      "import": "./src/styles.css",
      "default": "./src/styles.css"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ghostd-web/client": "workspace:*",
    "@ghostd-web/dom": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@internal/ts": "workspace:*",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "terminal",
    "react",
    "ghostd"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/semistrict/ghostd",
  "repository": {
    "type": "git",
    "url": "https://github.com/semistrict/ghostd",
    "directory": "packages/@ghostd/react"
  }
}
