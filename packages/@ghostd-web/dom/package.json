{
  "name": "@ghostd-web/dom",
  "version": "0.3.0",
  "description": "DOM renderer, input handler, and orchestrator for ghostd-web",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./css": {
      "style": "./src/terminal.css",
      "import": "./src/terminal.css",
      "default": "./src/terminal.css"
    },
    "./src/terminal.css": {
      "style": "./src/terminal.css",
      "import": "./src/terminal.css",
      "default": "./src/terminal.css"
    }
  },
  "files": [
    "src",
    "src/terminal.css"
  ],
  "scripts": {
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ghostd-web/core": "workspace:*"
  },
  "devDependencies": {
    "@internal/ts": "workspace:*",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "terminal",
    "emulator",
    "zig",
    "dom",
    "xterm"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/semistrict/ghostd",
  "repository": {
    "type": "git",
    "url": "https://github.com/semistrict/ghostd",
    "directory": "packages/@ghostd-web/dom"
  }
}
